// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String    @default("admin123")
  organizationName String?   @default("My Organization")
  allowedPages     String?   @default("overview,employees,leaves,attendance,clients,system_status,messages,task_allocation,events,work_submissions,leads")
  inviteToken      String?   @unique
  activeOtp        String?
  otpExpiresAt     DateTime?
  createdAt        DateTime  @default(now())
  isTeamLead       Boolean   @default(false)
  employeeId       String?   @unique
}

model Employee {
  id           String   @id // 6-digit alphanumeric generated code
  firstName    String
  middleName   String?
  lastName     String
  email        String   @unique
  phone        String
  wingName     String
  wingLeadName String
  role         String   @default("Employee")
  createdAt    DateTime @default(now())
  password     String?
  activeOtp    String?
  otpExpiresAt DateTime?
  /// UNSPECIFIED | MALE | FEMALE
  gender       String   @default("UNSPECIFIED")
  fcmToken     String?
  homeLat      Float?
  homeLng      Float?
  homePlusCode String?
  homeAddress  String?
  homeRadiusM  Int      @default(100)
  /// After first save, false until admin allows a change again
  homeEditAllowed Boolean @default(true)
  /// Profile photo as data URL (compressed JPEG) or https URL
  photoUrl     String?
  /// Admin-uploaded employee ID card image (data URL or https)
  idCardUrl    String?
  /// Last known device location (continuous while app monitors / on shift)
  lastLat      Float?
  lastLng      Float?
  lastLocationAt DateTime?
  /// Admin requested personal live tracking (independent of global)
  liveTrackActive Boolean @default(false)
  sosIncidents SosIncident[]
  safetyTrips  SafetyTrip[]
}

/// Admin global live-tracking switch (start/stop all employees).
model LiveTrackConfig {
  id        String    @id @default("global")
  active    Boolean   @default(false)
  startedAt DateTime?
  startedBy String?
  updatedAt DateTime  @updatedAt
}

model SosIncident {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  status      String    @default("OPEN") // OPEN | RESOLVED
  lat         Float
  lng         Float
  note        String?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([employeeId])
}

model SafetyTrip {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  status      String    @default("IN_TRANSIT") // IN_TRANSIT | ARRIVED_HOME | CANCELLED
  /// IST calendar day key YYYY-MM-DD for date-wise admin filters
  dateKey     String?
  lat         Float?
  lng         Float?
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  updatedAt   DateTime  @updatedAt
  points      SafetyTripPoint[]

  @@index([status])
  @@index([employeeId])
  @@index([dateKey])
  @@index([employeeId, dateKey])
}

/// Continuous GPS trail while a girl is going home (admin live + history).
model SafetyTripPoint {
  id         String     @id @default(uuid())
  tripId     String
  trip       SafetyTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  lat        Float
  lng        Float
  recordedAt DateTime   @default(now())

  @@index([tripId])
  @@index([recordedAt])
  @@index([tripId, recordedAt])
}

model Task {
  id           String   @id @default(uuid())
  title        String
  description  String
  reportTo     String
  assigneeId   String   // Employee ID or "ALL"
  assigneeName String   // Employee Name or "All Employees"
  deadline     DateTime
  status       String   @default("Pending") // e.g. Pending, In Progress, Completed
  mode         String   @default("Onsite")  // e.g. Remote, Onsite, Hybrid
  allocatorName String?
  allocatorRole String?
  createdAt    DateTime @default(now())
}

model Leave {
  id           String   @id @default(uuid())
  employeeId   String
  employeeName String
  startDate    DateTime
  endDate      DateTime
  type         String
  reason       String
  status       String   @default("Pending") // Pending, Approved, Ignored, Cancelled
  createdAt    DateTime @default(now())
}

model Attendance {
  id           String   @id @default(uuid())
  employeeId   String
  employeeName String
  date         String   // e.g. "2026-07-10"
  checkIn      String   // e.g. "09:00 AM"
  checkOut     String?  // e.g. "06:00 PM"
  status       String   // e.g. Present, Checked In
  /// True after near-checkout FCM or auto check-out (dedupe reminders)
  checkoutReminderSent Boolean @default(false)
  createdAt    DateTime @default(now())
}

model Message {
  id             String            @id @default(uuid())
  channel        String            // e.g. "public", "marketing", "technical", "core", or direct "dm:A:B"
  senderId       String
  senderName     String
  content        String            @default("")
  /// image | video | file
  attachmentType String?
  attachmentName String?
  /// data URL or https URL (keep small — Vercel body limit)
  attachmentUrl  String?           @db.Text
  replyToId      String?
  replyPreview   String?
  createdAt      DateTime          @default(now())
  editedAt       DateTime?
  reactions      MessageReaction[]
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  userName  String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model ChannelAccessRequest {
  id           String   @id @default(uuid())
  employeeId   String
  employeeName String
  channel      String   // "marketing", "technical", "core"
  status       String   @default("Pending") // "Pending", "Approved", "Rejected"
  createdAt    DateTime @default(now())
  @@unique([employeeId, channel])
}

model Event {
  id                  String   @id @default(uuid())
  title               String
  description         String
  organisingCollege   String
  representatives     String   // JSON array of { id, name } objects (max 5)
  startDate           DateTime
  endDate             DateTime
  startTime           String   // e.g. "09:00 AM"
  endTime             String   // e.g. "05:00 PM"
  venueAddress        String
  allowed             Boolean  @default(true)
  source              String   @default("Manual") // Manual, Student Tribe, Luma, Devfolio, Unstop
  sourceUrl           String?
  imageUrl            String?
  createdAt           DateTime @default(now())
}

model WorkSubmission {
  id           String   @id @default(uuid())
  employeeId   String
  employeeName String
  title        String
  description  String
  taskId       String?  // Optional linked task ID
  taskTitle    String?  // Optional linked task title
  hoursSpent   Float
  status       String   @default("Submitted") // Submitted, Reviewed, Approved, Needs Revision
  adminNote    String?
  submittedAt  DateTime @default(now())
}

model Lead {
  id           String   @id @default(uuid())
  businessName String
  contactName  String?
  email        String?
  phone        String?
  website      String?
  location     String?
  category     String?
  source       String   // JustDial, Yelp, Sulekha, Upwork, LinkedIn, Clutch, Freelancer, etc.
  sourceUrl    String?
  description  String?
  rating       String?
  reviewCount  String?
  status       String   @default("New")   // New, Contacted, Qualified, Proposal, Won, Lost
  priority     String   @default("Medium") // Low, Medium, High
  notes        String?
  assignedTo   String?  // employee ID
  allowed      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model HrCompany {
  id                  String   @id @default(uuid())
  companyName         String
  website             String?
  industry            String?
  location            String?
  hrName              String
  hrEmail             String?
  hrPhone             String?
  source              String   @default("Manual") // Manual, Arbeitnow
  sourceUrl           String?
  notes               String?
  status              String   @default("New")    // New, Contacted, Rejected, Hired
  allowed             Boolean  @default(true)     // false for crawled records awaiting approval
  assignedEmployeeId  String?  // Relates to Employee.id
  createdAt           DateTime @default(now())
}

/// Offices & QR for mobile geofence check-in (Neon — not Firebase)
model Office {
  id           String     @id @default(uuid())
  name         String
  address      String?
  lat          Float
  lng          Float
  plusCode     String?
  radiusMeters Int        @default(75)
  geofenceM    Int        @default(300)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  qrs          OfficeQr[]
}

model OfficeQr {
  id        String   @id @default(uuid())
  officeId  String
  label     String
  token     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  office    Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([officeId])
}
